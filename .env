# ==================== Application ====================
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3001

# ==================== Database ====================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=nicat
DB_SSL=false
DB_LOGGING=false

# ==================== Redis ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ==================== JWT ====================
JWT_SECRET=nicat-jwt-secret-dev-2026-change-in-production
JWT_REFRESH_SECRET=nicat-refresh-secret-dev-2026-change-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ==================== Stripe ====================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ==================== CORS ====================
# Leave empty to allow all origins in development
# Set specific origin in production (e.g., https://nicat.com)
CORS_ORIGIN=

# ==================== AWS S3 ====================
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# ==================== Encryption ====================
ENCRYPTION_KEY=nicat-encryption-key-dev-2026
ENCRYPTION_IV=0000000000000000
